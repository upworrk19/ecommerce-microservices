{
  "info": {
    "name": "Commerce — Distributed Platform",
    "description": "End-to-end API collection for the Distributed Commerce Platform, routed through the YARP gateway (http://localhost:8080).\n\nUsage:\n1. Start the stack: `docker compose up -d --build`\n2. Run **Auth / Register** once (creates the demo user).\n3. Run **Auth / Login** — its test script captures the JWT into the `token` collection variable automatically; every protected request then sends `Authorization: Bearer {{token}}`.\n4. Run the rest top-to-bottom, or use the **Golden Path** folder to replay the full flow.\n\nDemo credentials: a@b.com / Passw0rd! (Identity enforces email-contains-@ and password length >= 8).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "email", "value": "a@b.com", "type": "string" },
    { "key": "password", "value": "Passw0rd!", "type": "string" },
    { "key": "productId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "description": "Creates a user. Open route (no auth). Returns 201 with {id,email}, or 409 if the email already exists, or 400 (ProblemDetails) if email/password fail validation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register: 201 or 409 (already exists)', () => pm.expect([201, 409]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "description": "Returns {accessToken}. The test script stores the JWT in the `token` collection variable so all protected requests authenticate automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login: 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.expect(json.accessToken, 'accessToken present').to.be.a('string').and.not.empty;",
                  "pm.collectionVariables.set('token', json.accessToken);",
                  "console.log('Saved JWT to {{token}} (', json.accessToken.length, 'chars )');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] },
            "description": "Requires Bearer JWT (enforced at the gateway AND re-validated by Catalog). Returns the 3 seeded products."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('products: 200', () => pm.response.to.have.status(200));",
                  "pm.test('3 seeded products', () => pm.expect(pm.response.json().length).to.eql(3));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Product by Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["products", "{{productId}}"] },
            "description": "Fetch a single product by GUID. 404 if it does not exist."
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            },
            "description": "Validates the JWT, checks the product via Catalog, persists the order, and publishes OrderPlaced through the MassTransit transactional outbox (same DB transaction). Returns 201 {id,totalPrice}. Quantity must be 1..1000. The test script saves the new order id into `orderId`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('order: 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.id) { pm.collectionVariables.set('orderId', json.id); }",
                  "pm.test('has totalPrice', () => pm.expect(json.totalPrice).to.be.a('number'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order by Id (scoped to caller)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["orders", "{{orderId}}"] },
            "description": "Returns the order only if it belongs to the calling user (IDOR-safe: another user's order returns 404, identical to not-found)."
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "My Notifications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/notifications/me", "host": ["{{baseUrl}}"], "path": ["notifications", "me"] },
            "description": "Returns notifications stored in Redis by the OrderPlaced consumer. After placing an order, allow ~1-2s for the async broker round-trip, then run this — you should see a 'confirmed' message."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('notifications: 200', () => pm.response.to.have.status(200));",
                  "// Note: may be empty if run immediately after Place Order — the event is async."
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Negative cases",
      "item": [
        {
          "name": "Orders without token -> 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}" },
            "description": "No bearer token — the gateway rejects with 401 before reaching the Order service."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('401 Unauthorized', () => pm.response.to.have.status(401));"] } }
          ]
        },
        {
          "name": "Order unknown product -> 404",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"99999999-9999-9999-9999-999999999999\",\n  \"quantity\": 1\n}" },
            "description": "Authenticated, but the product GUID does not exist in Catalog — Order returns 404."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('404 Not Found', () => pm.response.to.have.status(404));"] } }
          ]
        },
        {
          "name": "Order invalid quantity -> 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 0\n}" },
            "description": "Quantity must be between 1 and 1000 — returns 400 ProblemDetails."
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"] } }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        { "name": "Gateway /health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] } } },
        { "name": "Identity /health", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "http://localhost:5101/health", "host": ["http://localhost:5101"], "path": ["health"] }, "description": "Direct to the service (bypasses gateway). Other services: catalog 5102, order 5103, notification 5104." } }
      ]
    }
  ]
}
